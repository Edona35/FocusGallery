							<a class="text-white text-decoration-none" aria-current="page" href="{{path('admin')}}">Admin</a>
						</li>
					{% endif %}

					<div class="d-flex align-items-center gap-4">

						<a href="#" class="text-white text-decoration-none">
							Galerie
						</a>


					</span>
					{% if app.user %}
						<li class="nav-item">
							<a class="text-white text-decoration-none" aria-current="page" href="{{path('app_logout')}}">Se déconnecter</a>
						</li>
					{% else %}
						<li class="nav-item">
							<a class="text-white text-decoration-none" aria-current="page" href="{{path('app_register')}}">S'inscrire</a>
						</li>
