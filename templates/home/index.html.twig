{% extends 'base.html.twig' %}

{% block title %}FocusGallery{% endblock %}

{% block body %}

<div class="container mt-4">

    <h1 class="text-center mb-5">
        Découvrez nos clichés
    </h1>


    <div class="d-flex justify-content-center gap-3 flex-wrap mb-5">



        <a
            href="{{ path('app_home') }}"
            class="btn rounded-pill px-4
            {{ activeCategory is not defined ? 'btn-dark text-white' : 'btn-light' }}"
        >
            Tous
        </a>

     

        {% for category in categories %}

            <a
                href="{{ path('app_category', {'id': category.id}) }}"
                class="btn rounded-pill px-4 text-white
                {{ activeCategory is defined and activeCategory == category.id ? 'shadow' : '' }}"
                style="background-color: {{ category.color|default('#6c757d') }}"
            >

                {{ category.name }}

            </a>

        {% endfor %}

    </div>

   

    <div class="row row-cols-1 row-cols-md-3 g-4">

        {% for photo in photos %}

            <div class="col">

                <div class="card h-100 border-0 shadow-sm">


                    <div class="ratio ratio-1x1 overflow-hidden rounded-top">

                        <img
                            src="{{ asset('uploads/photos/' ~ photo.imageName) }}"
                            alt="{{ photo.title }}"
                            class="img-fluid w-100 h-100 object-fit-cover"
                        >

                    </div>

                 

                    <div class="card-body d-flex flex-column p-3">


                        <div class="d-flex justify-content-between align-items-center mb-2">

                            <h5 class="mb-0">
                                {{ photo.title }}
                            </h5>

                            <span
                                class="badge text-white"
                                style="background-color: {{ photo.category.color|default('#6c757d') }}"
                            >
                                {{ photo.category.name }}
                            </span>

                        </div>

                      

                        <p class="text-muted">

                            {{ photo.description|slice(0, 60) }}...

                        </p>

                  

                        <a
                            href="{{ path('photo_show', {'id': photo.id}) }}"
                            class="btn btn-dark btn-sm mt-auto"
                        >
                            Voir 
                        </a>

                    </div>

                </div>

            </div>

        {% else %}

            <div class="col-12">

                <p class="text-center">
                    Aucune photo disponible
                </p>

            </div>

        {% endfor %}

    </div>

</div>

{% endblock %}